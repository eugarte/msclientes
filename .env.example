NODE_ENV=development
PORT=3002

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=password
DB_DATABASE=msclientes

# JWT Configuration (from msseguridad)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ISSUER=msseguridad
JWT_AUDIENCE=msclientes
JWT_EXPIRATION=24h

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Redis (for caching - optional)
REDIS_HOST=localhost
REDIS_PORT=6379

# GDPR Settings
GDPR_DATA_RETENTION_DAYS=2555
GDPR_ANONYMIZATION_ENABLED=true

# msseguridad Integration
MSSEGURIDAD_URL=http://localhost:3001
MSSEGURIDAD_API_KEY=internal-api-key
